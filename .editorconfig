root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cpp,hpp,h,cc,cxx,tpp,inl}]
indent_size = 4

[*.{cmake,txt}]
indent_size = 2

[CMakeLists.txt]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
indent_size = 2
